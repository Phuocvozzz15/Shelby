
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shelby Island Game</title>

<style>
body{
margin:0;
overflow:hidden;
background:#000;
font-family:Arial, sans-serif;
}

canvas{
display:block;
}

#ui{
position:absolute;
top:10px;
left:0;
width:100%;
display:flex;
justify-content:space-between;
padding:0 20px;
color:white;
font-size:18px;
box-sizing:border-box;
}

#center{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
color:white;
font-size:28px;
text-align:center;
}

button{
padding:10px 16px;
border:none;
border-radius:8px;
background:#ff3cac;
color:white;
}
</style>
</head>

<body>

<div id="ui">
<div id="score">Score: 0</div>
<button id="connect">Enable Shelby Storage</button>
</div>

<div id="center">Tap / Click to Start</div>

<canvas id="game"></canvas>

<script type="module">

/* =========================
   OPTIONAL SHELBY STORAGE
========================= */

let shelbyClient = null
let shelbyReady = false

async function initShelby(){
try {

const sdk = await import("https://esm.sh/@shelby-protocol/sdk/browser")
const aptos = await import("https://esm.sh/@aptos-labs/ts-sdk")

const { ShelbyClient } = sdk
const { Network, Account } = aptos

const apiKey = "PUT_YOUR_SHELBY_API_KEY_HERE"

if(apiKey === "PUT_YOUR_SHELBY_API_KEY_HERE") {
alert("Add your Shelby API key in the HTML file to enable storage.")
return
}

shelbyClient = new ShelbyClient({
network: Network.SHELBYNET,
apiKey: apiKey
})

shelbyReady = true

alert("Shelby storage enabled")

} catch(err){
console.log("Shelby init failed:", err)
}
}

document.getElementById("connect").onclick = initShelby

async function saveScoreShelby(score){
if(!shelbyReady) return

try{

const data = new Blob([JSON.stringify({score:score,date:Date.now()})])

await shelbyClient.upload({
blobData:data,
blobName:"island-game-score-"+Date.now()+".json"
})

console.log("Score saved to Shelby")

}catch(e){
console.log("Shelby upload error",e)
}
}


/* =========================
   GAME ENGINE
========================= */

const canvas = document.getElementById("game")
const ctx = canvas.getContext("2d")

function resize(){
canvas.width = window.innerWidth
canvas.height = window.innerHeight
paddle.y = canvas.height - 80
}

window.addEventListener("resize",resize)

let score = 0
let running = false
let speedMultiplier = 1

const logo = new Image()
logo.src = "data:image/jpeg;base64,"

let paddle = {
x:200,
y:0,
width:220,
height:25
}

let ball = {
x:200,
y:200,
vx:5,
vy:-5,
size:60
}

let powerUp = null
let extraBalls = []
let powerActive = false

resize()

function resetBall(){
ball.x = canvas.width/2
ball.y = canvas.height/2
ball.vx = (Math.random()*4+3)*(Math.random()>0.5?1:-1)
ball.vy = -(Math.random()*4+3)
}

function spawnPower(){
powerUp = {
x:Math.random()*canvas.width,
y:80,
size:40
}
}

function activatePower(){
powerActive = true

extraBalls.push({
x:ball.x,
y:ball.y,
vx:-ball.vx,
vy:ball.vy,
size:ball.size
})

setTimeout(()=>{
powerActive=false
extraBalls=[]
},10000)
}

function movePaddle(x){
paddle.x = x - paddle.width/2
if(paddle.x < 0) paddle.x = 0
if(paddle.x + paddle.width > canvas.width)
paddle.x = canvas.width - paddle.width
}

window.addEventListener("mousemove",e=>movePaddle(e.clientX))
window.addEventListener("touchmove",e=>movePaddle(e.touches[0].clientX))

window.addEventListener("click",startGame)
window.addEventListener("touchstart",startGame)

function startGame(){
if(running) return
score=0
speedMultiplier=1
extraBalls=[]
document.getElementById("center").style.display="none"
resetBall()
running=true
}

function updateBall(b){

b.x += b.vx*speedMultiplier
b.y += b.vy*speedMultiplier

if(b.x<0||b.x+b.size>canvas.width) b.vx*=-1
if(b.y<0) b.vy*=-1

if(
b.x < paddle.x + paddle.width &&
b.x + b.size > paddle.x &&
b.y + b.size > paddle.y &&
b.y < paddle.y + paddle.height
){

b.vy *= -1
b.y = paddle.y - b.size

score++

if(score % 5 === 0) speedMultiplier += 0.2
if(score % 8 === 0 && !powerUp) spawnPower()

document.getElementById("score").innerText="Score: "+score
}

if(b.y > canvas.height){
running=false
document.getElementById("center").innerHTML="Game Over<br>Tap to Restart"
document.getElementById("center").style.display="block"

saveScoreShelby(score)
}

}

function update(){
if(!running) return

updateBall(ball)
extraBalls.forEach(updateBall)

if(powerUp){

powerUp.y +=2

if(
ball.x < powerUp.x+powerUp.size &&
ball.x+ball.size>powerUp.x &&
ball.y < powerUp.y+powerUp.size &&
ball.y+ball.size>powerUp.y
){
activatePower()
powerUp=null
}

if(powerUp && powerUp.y > canvas.height) powerUp=null
}

}

function draw(){
ctx.clearRect(0,0,canvas.width,canvas.height)

ctx.fillStyle="white"
ctx.fillRect(paddle.x,paddle.y,paddle.width,paddle.height)

ctx.drawImage(logo,ball.x,ball.y,ball.size,ball.size)

extraBalls.forEach(b=>ctx.drawImage(logo,b.x,b.y,b.size,b.size))

if(powerUp){
ctx.fillStyle="#00ffcc"
ctx.beginPath()
ctx.arc(powerUp.x,powerUp.y,powerUp.size/2,0,Math.PI*2)
ctx.fill()
}
}

function loop(){
update()
draw()
requestAnimationFrame(loop)
}

loop()

</script>

</body>
</html>
